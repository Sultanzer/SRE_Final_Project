{
  "title": "SRE Capstone - E-commerce API",
  "uid": "sre-capstone-ecommerce",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"ecommerce-api\"}[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"ecommerce-api\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"ecommerce-api\"}[5m])) * 100",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ecommerce-api\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Availability SLO 99%",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(http_requests_total{job=\"ecommerce-api\",status_code=~\"5..\"}[30m])) / sum(rate(http_requests_total{job=\"ecommerce-api\"}[30m])))) * 100",
          "legendFormat": "SLO"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error Budget Remaining",
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "max(0, (0.01 - (sum(rate(http_requests_total{job=\"ecommerce-api\",status_code=~\"5..\"}[30m])) / sum(rate(http_requests_total{job=\"ecommerce-api\"}[30m])))) / 0.01 * 100)",
          "legendFormat": "Budget %"
        }
      ]
    }
  ]
}